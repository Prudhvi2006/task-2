# Copy this file to .env and replace the values with your MongoDB Atlas and SMTP connection details.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net
MONGO_DB=mini_crm
PORT=4000

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
